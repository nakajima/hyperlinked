	sourceType: HyperlinkSourceTypeEnum!
	rssFeedId: Int
	createdAt: String!
	updatedAt: String!
	hyperlinkProcessingJob(filters: HyperlinkProcessingJobFilterInput, orderBy: HyperlinkProcessingJobOrderInput, pagination: PaginationInput): HyperlinkProcessingJobConnection!
	hyperlinkArtifact(filters: HyperlinkArtifactFilterInput, orderBy: HyperlinkArtifactOrderInput, pagination: PaginationInput): HyperlinkArtifactConnection!
	sublinks(filters: HyperlinkFilterInput, orderBy: HyperlinkOrderInput, pagination: PaginationInput): HyperlinkConnection!
	discoveredVia: [HyperlinkRef!]!
	screenshotUrl: String
	screenshotDarkUrl: String
	thumbnailUrl: String
	thumbnailDarkUrl: String
}

type HyperlinkArtifact {
