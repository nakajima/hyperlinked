}

input PaginationInput @oneOf {
	cursor: CursorInput
	page: PageInput
	offset: OffsetInput
}

type Query {
	hyperlinks(filters: HyperlinkFilterInput, orderBy: HyperlinkOrderInput, pagination: PaginationInput, q: String): HyperlinkConnection!
	updatedHyperlinks(updatedAt: String!): UpdatedHyperlinksPayload!
	hyperlinkProcessingJob(filters: HyperlinkProcessingJobFilterInput, having: HyperlinkProcessingJobHavingInput, orderBy: HyperlinkProcessingJobOrderInput, pagination: PaginationInput): HyperlinkProcessingJobConnection!
	hyperlinkArtifact(filters: HyperlinkArtifactFilterInput, having: HyperlinkArtifactHavingInput, orderBy: HyperlinkArtifactOrderInput, pagination: PaginationInput): HyperlinkArtifactConnection!
	_sea_orm_entity_metadata(table_name: String!): Table!
}

input StringArrayFilterInput {
	array_contains: [String!]
	array_contained: [String!]
	array_overlap: [String!]
}

input StringFilterInput {
	eq: String
	ne: String
	gt: String
	gte: String
	lt: String
	lte: String
	ci_eq: String
	is_in: [String!]
	is_not_in: [String!]
	is_null: Boolean
	contains: String
	starts_with: String
	ends_with: String
	like: String
	not_like: String
	between: [String!]
	not_between: [String!]
}

type Table {
	columns: [Column!]!
	primary_key: [String!]!
