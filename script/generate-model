#!/usr/bin/env python3

from __future__ import annotations

import re
import sys
from dataclasses import dataclass
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent

ENTITY_MOD = ROOT / "src/entity/mod.rs"
ENTITY_PRELUDE = ROOT / "src/entity/prelude.rs"
DB_SCHEMA = ROOT / "src/db/schema.rs"


@dataclass
class Field:
    name: str
    raw_type: str
    rust_type: str
    sea_orm_attrs: list[str]


TYPE_MAP: dict[str, tuple[str, list[str]]] = {
    "string": ("String", []),
    "text": ("String", ['column_type = "Text"']),
    "int": ("i32", []),
    "integer": ("i32", []),
    "bigint": ("i64", []),
    "i64": ("i64", []),
    "bool": ("bool", []),
    "boolean": ("bool", []),
    "datetime": ("DateTime", []),
    "json": ("Json", []),
    "float": ("f32", []),
    "double": ("f64", []),
}


def usage() -> int:
    print(
        "Usage: script/generate-model Name field:type [field:type ...]\n"
        "Example: script/generate-model Bookmark title:string notes:text published:boolean"
    )
    return 1


def camel_to_snake(value: str) -> str:
    s1 = re.sub(r"(.)([A-Z][a-z]+)", r"\1_\2", value)
    s2 = re.sub(r"([a-z0-9])([A-Z])", r"\1_\2", s1)
    return s2.replace("-", "_").lower()


def parse_args(argv: list[str]) -> tuple[str, str, list[Field]]:
    if len(argv) < 3:
        raise ValueError("missing model name or fields")

    raw_name = argv[1].strip()
    if not re.fullmatch(r"[A-Z][A-Za-z0-9]*", raw_name):
        raise ValueError("model name must be CamelCase, like Bookmark or ReadingListItem")

    module_name = camel_to_snake(raw_name)
    table_name = module_name

    fields: list[Field] = []
    seen_names: set[str] = {"id", "created_at", "updated_at"}

    for raw_field in argv[2:]:
        if ":" not in raw_field:
            raise ValueError(f"field '{raw_field}' must look like name:type")

        name, raw_type = raw_field.split(":", 1)
        name = name.strip()
        raw_type = raw_type.strip()

        if not re.fullmatch(r"[a-z][a-z0-9_]*", name):
            raise ValueError(
                f"field name '{name}' must be snake_case and start with a lowercase letter"
            )
        if name in seen_names:
            raise ValueError(f"duplicate or reserved field name '{name}'")
        seen_names.add(name)

        nullable = raw_type.endswith("?")
        base_type = raw_type[:-1] if nullable else raw_type
        if base_type not in TYPE_MAP:
            supported = ", ".join(sorted(TYPE_MAP))
            raise ValueError(
                f"unsupported type '{raw_type}'. Supported types: {supported}, plus optional ? suffix"
            )

        rust_type, attrs = TYPE_MAP[base_type]
        final_type = f"Option<{rust_type}>" if nullable else rust_type
        fields.append(
            Field(
                name=name,
                raw_type=raw_type,
                rust_type=final_type,
                sea_orm_attrs=list(attrs),
            )
        )

    return raw_name, table_name, fields


def ensure_file_absent(path: Path) -> None:
    if path.exists():
        raise ValueError(f"refusing to overwrite existing file: {path.relative_to(ROOT)}")


def insert_sorted_line(path: Path, line: str, anchor_prefix: str) -> None:
    content = path.read_text()
    lines = content.splitlines()
    if line in lines:
        return

    anchor_indexes = [index for index, current in enumerate(lines) if current.startswith(anchor_prefix)]
    insert_at = len(lines)
    for index in anchor_indexes:
        if lines[index] > line:
            insert_at = index
            break

    lines.insert(insert_at, line)
    path.write_text("\n".join(lines) + "\n")


def insert_sorted_use_item(path: Path, item: str) -> None:
    content = path.read_text()
    match = re.search(r"use crate::entity::\{(?P<body>.*?)\};", content, re.S)
    if not match:
        raise ValueError(f"could not find crate::entity use block in {path.relative_to(ROOT)}")

    existing_items = [part.strip() for part in match.group("body").replace("\n", " ").split(",")]
    existing_items = [part for part in existing_items if part]
    if item in existing_items:
        return

    existing_items.append(item)
    existing_items = sorted(existing_items)

    replacement = "use crate::entity::{\n    " + ", ".join(existing_items) + ",\n};"
    updated = content[: match.start()] + replacement + content[match.end() :]
    path.write_text(updated)


def insert_create_entity_call(path: Path, entity_module: str) -> None:
    content = path.read_text()
    line = f"    create_entity(connection, {entity_module}::Entity).await?;"
    if line in content:
        return

    marker = "    apply_sqlite_extras(connection).await\n"
    if marker not in content:
        raise ValueError(f"could not find schema sync insertion point in {path.relative_to(ROOT)}")

    updated = content.replace(marker, line + "\n" + marker, 1)
    path.write_text(updated)


def entity_module_content(table_name: str, fields: list[Field]) -> str:
    field_lines = []
    for field in fields:
        attrs = field.sea_orm_attrs[:]
        attr_line = ""
        if attrs:
            attr_line = f"    #[sea_orm({', '.join(attrs)})]\n"
        field_lines.append(f"{attr_line}    pub {field.name}: {field.rust_type},")

    fields_block = "\n".join(field_lines)

    return f'''//! `SeaORM` Entity.

use sea_orm::entity::prelude::*;

#[derive(Clone, Debug, PartialEq, DeriveEntityModel, Eq)]
#[sea_orm(table_name = "{table_name}")]
pub struct Model {{
    #[sea_orm(primary_key)]
    pub id: i32,
{fields_block}
    pub created_at: DateTime,
    pub updated_at: DateTime,
}}

#[derive(Copy, Clone, Debug, EnumIter, DeriveRelation)]
pub enum Relation {{}}

impl ActiveModelBehavior for ActiveModel {{}}
'''


def main(argv: list[str]) -> int:
    try:
        model_name, table_name, fields = parse_args(argv)
        module_name = camel_to_snake(model_name)

        entity_path = ROOT / f"src/entity/{module_name}.rs"
        ensure_file_absent(entity_path)

        entity_path.write_text(entity_module_content(table_name, fields))

        insert_sorted_line(ENTITY_MOD, f"pub mod {module_name};", anchor_prefix="pub mod ")
        insert_sorted_line(
            ENTITY_PRELUDE,
            f"pub use super::{module_name}::Entity as {model_name};",
            anchor_prefix="pub use super::",
        )
        insert_sorted_use_item(DB_SCHEMA, module_name)
        insert_create_entity_call(DB_SCHEMA, module_name)

        print("Created:")
        print(f"  {entity_path.relative_to(ROOT)}")
        print("Updated:")
        for path in [ENTITY_MOD, ENTITY_PRELUDE, DB_SCHEMA]:
            print(f"  {path.relative_to(ROOT)}")
        print("Note: schema is entity-first; no app model, test, or migration was generated.")
        return 0
    except ValueError as error:
        print(f"error: {error}", file=sys.stderr)
        return usage()


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
