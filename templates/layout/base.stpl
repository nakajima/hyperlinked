<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= self.title %></title>
    <link rel="stylesheet" href="https://use.typekit.net/bpw6fxi.css" />
    <link rel="stylesheet" href="/assets/reset.css" />
    <link rel="stylesheet" href="/assets/app.css" />
    <script type="module" src="https://cdn.jsdelivr.net/npm/@github/relative-time-element/+esm"></script>
    <script src="/assets/app.js" defer></script>
  </head>
  <body>
    <% include!("../shared/_header.stpl"); %>
    <main class="vstack gap-3">
      <% if let Some(dev_restart_alert) = self.dev_restart_alert.as_ref() { %>
        <p class="flash flash-dev-alert" role="alert"><%= dev_restart_alert %></p>
      <% } %>
      <% if let Some(notice) = self.notice_flash.as_ref() { %>
        <p class="flash flash-notice" role="status"><%= notice %></p>
      <% } %>
      <% if let Some(alert) = self.alert_flash.as_ref() { %>
        <p class="flash flash-alert" role="alert"><%= alert %></p>
      <% } %>
      <%- self.body_html %>
    </main>
  </body>
</html>
