<section class="flex flex-col gap-4" aria-labelledby="admin-heading">
  <article class="flex flex-col gap-[0.4rem]">
    <h2 id="admin-heading" class="text-2xl font-semibold leading-8 tracking-tight"><%= self.active_tab_title() %></h2>
    <p class="text-sm text-tertiary"><%= self.active_tab_summary() %></p>
  </article>

    <% if self.is_overview_tab() { %>
      <section class="flex flex-col gap-3 rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-3">
        <h3 class="text-lg font-semibold leading-7 tracking-tight">Runtime status</h3>
        <p class="text-sm text-tertiary" data-admin-version>Version <code class="font-mono text-[0.9em]"><%= self.app_version %></code></p>
        <p class="text-sm text-tertiary" data-admin-mathpix>
          PDF Mathpix parsing:
          <% if self.mathpix.enabled { %>
            <span class="text-primary">Enabled</span>
          <% } else { %>
            <span class="text-primary">Disabled</span>
            <span>(<code class="font-mono text-[0.9em]"><%= self.mathpix.reason %></code>)</span>
          <% } %>
        </p>
        <p class="text-sm text-tertiary" data-admin-mathpix-usage>
          Current month: <code class="font-mono text-[0.9em]"><%= self.mathpix_usage.month.total_requests %> requests</code>,
          estimated <code class="font-mono text-[0.9em]"><%= self.format_usd_estimate(self.mathpix_usage.month.estimated_cost_usd) %></code>
        </p>
        <p class="text-sm text-tertiary" data-admin-mathpix-usage-total>
          All-time: <code class="font-mono text-[0.9em]"><%= self.mathpix_usage.all_time.total_requests %> requests</code>,
          estimated <code class="font-mono text-[0.9em]"><%= self.format_usd_estimate(self.mathpix_usage.all_time.estimated_cost_usd) %></code>
          <span>(estimate based on public Mathpix pricing)</span>
        </p>
        <% if !self.mathpix_usage.month.breakdown.is_empty() { %>
          <section class="flex flex-col gap-2" data-admin-mathpix-breakdown-month>
            <h4 class="text-sm font-semibold leading-6">Current month usage breakdown</h4>
            <div class="overflow-x-auto">
              <table class="min-w-max border-collapse bg-form-control text-sm [&_th]:border [&_th]:border-form-control-border [&_th]:px-2 [&_th]:py-2 [&_th]:text-left [&_th]:font-normal [&_td]:border [&_td]:border-form-control-border [&_td]:px-2 [&_td]:py-2 [&_td]:align-top" aria-label="Current month Mathpix usage breakdown">
                <thead>
                  <tr>
                    <th>Usage type</th>
                    <th>Pricing class</th>
                    <th>Count</th>
                    <th>Estimated</th>
                  </tr>
                </thead>
                <tbody>
                  <% for item in self.mathpix_usage.month.breakdown.iter() { %>
                    <tr>
                      <td><code class="font-mono text-[0.9em]"><%= item.usage_type.as_str() %></code></td>
                      <td><code class="font-mono text-[0.9em]"><%= item.cost_class.as_str() %></code></td>
                      <td><%= item.count %></td>
                      <td><code class="font-mono text-[0.9em]"><%= self.format_usd_estimate(item.estimated_cost_usd) %></code></td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </section>
        <% } %>
        <% if !self.mathpix_usage.all_time.breakdown.is_empty() { %>
          <section class="flex flex-col gap-2" data-admin-mathpix-breakdown-all-time>
            <h4 class="text-sm font-semibold leading-6">All-time usage breakdown</h4>
            <div class="overflow-x-auto">
              <table class="min-w-max border-collapse bg-form-control text-sm [&_th]:border [&_th]:border-form-control-border [&_th]:px-2 [&_th]:py-2 [&_th]:text-left [&_th]:font-normal [&_td]:border [&_td]:border-form-control-border [&_td]:px-2 [&_td]:py-2 [&_td]:align-top" aria-label="All-time Mathpix usage breakdown">
                <thead>
                  <tr>
                    <th>Usage type</th>
                    <th>Pricing class</th>
                    <th>Count</th>
                    <th>Estimated</th>
                  </tr>
                </thead>
                <tbody>
                  <% for item in self.mathpix_usage.all_time.breakdown.iter() { %>
                    <tr>
                      <td><code class="font-mono text-[0.9em]"><%= item.usage_type.as_str() %></code></td>
                      <td><code class="font-mono text-[0.9em]"><%= item.cost_class.as_str() %></code></td>
                      <td><%= item.count %></td>
                      <td><code class="font-mono text-[0.9em]"><%= self.format_usd_estimate(item.estimated_cost_usd) %></code></td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </section>
        <% } %>
        <% if let Some(warning) = self.mathpix_usage.warning.as_deref() { %>
          <p class="text-sm text-tertiary" data-admin-mathpix-usage-warning>
            <%= warning %>
          </p>
        <% } %>
      </section>

      <% if self.chromium.has_missing_binary() { %>
        <section class="flex flex-col gap-3 rounded-[0.4rem] border border-invalid bg-form-control px-3 py-3" aria-labelledby="chrome-setup-heading">
          <h3 id="chrome-setup-heading" class="text-lg font-semibold leading-7 tracking-tight text-alert">Screenshot browser setup required</h3>
          <p class="text-sm">
            Chromium/Chrome was not found, so screenshot capture jobs will fail until this is fixed.
          </p>
          <p class="text-sm">
            Chromium binary:
            <code class="font-mono text-[0.9em]"><%= self.chromium.chromium_path %></code>
            <% if self.chromium.chromium_found { %>(found at <code class="font-mono text-[0.9em]"><%= self.chromium.chromium_resolved_path.as_deref().unwrap_or("") %></code>)<% } else { %>(not found)<% } %>
          </p>
          <p class="text-sm">Set this and restart the server:</p>
          <pre class="overflow-x-auto rounded-[0.4rem] border border-form-control-border bg-tertiary p-3 text-sm leading-5"><code>export CHROMIUM_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"</code></pre>
          <p class="text-sm">After restarting, reprocess links that are missing screenshots.</p>
        </section>
      <% } %>

      <% if self.fonts.has_missing_fonts() { %>
        <section class="flex flex-col gap-3 rounded-[0.4rem] border border-invalid bg-form-control px-3 py-3" aria-labelledby="fonts-setup-heading">
          <h3 id="fonts-setup-heading" class="text-lg font-semibold leading-7 tracking-tight text-alert">Screenshot font setup recommended</h3>
          <p class="text-sm">
            Screenshot capture is running on <code class="font-mono text-[0.9em]"><%= self.fonts.platform.as_str() %></code> and required font families are missing.
          </p>
          <p class="text-sm">
            Required families:
            <code class="font-mono text-[0.9em]"><%= self.fonts.required_families.join(", ") %></code>
          </p>
          <% if !self.fonts.fontconfig_found { %>
            <p class="text-sm">
              <code class="font-mono text-[0.9em]">fontconfig</code> was not detected.
              <% if let Some(error) = self.fonts.fontconfig_error.as_deref() { %>
                Last error: <code class="font-mono text-[0.9em]"><%= error %></code>
              <% } %>
            </p>
          <% } %>
          <% if !self.fonts.missing_families.is_empty() { %>
            <p class="text-sm">
              Missing families:
              <code class="font-mono text-[0.9em]"><%= self.fonts.missing_families.join(", ") %></code>
            </p>
          <% } %>
          <% if !self.fonts.resolved_matches.is_empty() { %>
            <div class="overflow-x-auto">
              <table class="min-w-max border-collapse bg-form-control text-sm [&_th]:border [&_th]:border-form-control-border [&_th]:px-2 [&_th]:py-2 [&_th]:text-left [&_th]:font-normal [&_td]:border [&_td]:border-form-control-border [&_td]:px-2 [&_td]:py-2 [&_td]:align-top" aria-label="Screenshot font matches">
                <thead>
                  <tr>
                    <th>Requested family</th>
                    <th>fc-match result</th>
                  </tr>
                </thead>
                <tbody>
                  <% for resolved in self.fonts.resolved_matches.iter() { %>
                    <tr>
                      <td><code class="font-mono text-[0.9em]"><%= resolved.family.as_str() %></code></td>
                      <td><code class="font-mono text-[0.9em]"><%= resolved.matched_font.as_deref().unwrap_or("not found") %></code></td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          <% } %>
          <% if let Some(install_hint) = self.fonts.install_hint.as_deref() { %>
            <p class="text-sm">Install packages and restart the server:</p>
            <pre class="overflow-x-auto rounded-[0.4rem] border border-form-control-border bg-tertiary p-3 text-sm leading-5"><code><%= install_hint %></code></pre>
          <% } %>
        </section>
      <% } %>

      <details class="flex flex-col gap-3 rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-3">
        <summary class="cursor-pointer text-lg font-semibold leading-7 tracking-tight">Diagnostics and examples</summary>

        <section class="flex flex-col gap-[0.4rem]">
          <h4 class="text-base font-semibold leading-6">Dataset stats</h4>
          <div class="overflow-x-auto">
            <table class="min-w-max border-collapse bg-form-control text-sm [&_th]:border [&_th]:border-form-control-border [&_th]:px-2 [&_th]:py-2 [&_th]:text-left [&_th]:font-normal [&_td]:border [&_td]:border-form-control-border [&_td]:px-2 [&_td]:py-2 [&_td]:align-top" aria-label="Dataset stats">
              <thead>
                <tr>
                  <th>Total links</th>
                  <th>Root links</th>
                  <th>Discovered links</th>
                  <th>Total artifacts</th>
                  <th>Total jobs</th>
                  <th>Active jobs</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><%= self.stats.total_hyperlinks %></td>
                  <td><%= self.stats.root_hyperlinks %></td>
                  <td><%= self.stats.discovered_hyperlinks %></td>
                  <td><%= self.stats.total_artifacts %></td>
                  <td><%= self.stats.total_processing_jobs %></td>
                  <td><%= self.stats.active_processing_jobs %></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="flex flex-col gap-[0.4rem]">
          <h4 class="text-base font-semibold leading-6">Flash examples</h4>
          <p class="rounded-[0.4rem] border border-notice-border bg-notice-bg px-3 py-[0.65rem] text-sm leading-5 text-notice" role="status">Notice example: Changes saved.</p>
          <p class="rounded-[0.4rem] border border-invalid bg-form-control px-3 py-[0.65rem] text-sm leading-5 text-alert" role="alert">Alert example: Something went wrong.</p>
          <p class="rounded-[0.4rem] border border-dev-alert-border bg-dev-alert-bg px-3 py-[0.65rem] text-sm leading-5 text-dev-alert" role="alert">Dev alert example: Restart failed.</p>
        </section>
      </details>
    <% } %>

    <% if self.is_artifacts_tab() { %>
      <section class="flex flex-col gap-3 rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-3">
        <h3 class="text-lg font-semibold leading-7 tracking-tight">Artifact collection settings</h3>
        <p class="text-sm text-tertiary">
          Control which artifact pipelines run for future processing.
        </p>
        <form action="/admin/artifact-settings" method="post" class="flex flex-col gap-3 text-sm [&_label]:text-sm [&_label]:font-normal [&_input[type='checkbox']]:mt-0.5 [&_input[type='checkbox']]:h-4 [&_input[type='checkbox']]:w-4 [&_input[type='checkbox']]:shrink-0 [&_input[type='checkbox']]:rounded [&_input[type='checkbox']]:border [&_input[type='checkbox']]:border-form-control-border [&_input[type='checkbox']]:bg-form-control [&_input[type='checkbox']]:accent-accent [&_input[type='checkbox']]:focus:outline-none [&_input[type='checkbox']]:focus:ring-2 [&_input[type='checkbox']]:focus:ring-accent/30">
          <div class="flex flex-col gap-[0.4rem]">
            <label class="flex items-start gap-2">
              <input type="checkbox" name="collect_source" value="1"<% if self.artifact_settings.collect_source { %> checked<% } %> />
              <span>Collect source artifacts (snapshot warc / pdf source)</span>
            </label>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="collect_screenshots" value="1"<% if self.artifact_settings.collect_screenshots { %> checked<% } %> />
              <span>Collect screenshot artifacts</span>
            </label>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="collect_screenshot_dark" value="1"<% if self.artifact_settings.collect_screenshot_dark { %> checked<% } %> />
              <span>Collect dark-mode screenshot variants</span>
            </label>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="collect_og" value="1"<% if self.artifact_settings.collect_og { %> checked<% } %> />
              <span>Collect Open Graph artifacts</span>
            </label>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="collect_readability" value="1"<% if self.artifact_settings.collect_readability { %> checked<% } %> />
              <span>Collect readability artifacts</span>
            </label>
          </div>

          <div class="flex flex-col gap-[0.4rem]">
            <p class="text-sm text-tertiary">If a pipeline is being disabled, optionally delete existing artifacts:</p>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="delete_source_on_disable" value="1" />
              <span>Also delete existing source artifacts</span>
            </label>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="delete_screenshots_on_disable" value="1" />
              <span>Also delete existing screenshot artifacts</span>
            </label>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="delete_og_on_disable" value="1" />
              <span>Also delete existing Open Graph artifacts</span>
            </label>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="delete_readability_on_disable" value="1" />
              <span>Also delete existing readability artifacts</span>
            </label>
          </div>

          <div class="flex flex-col gap-[0.4rem]">
            <p class="text-sm text-tertiary">If a pipeline is being enabled, optionally queue missing backfill jobs:</p>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="queue_source_on_enable" value="1" />
              <span>Queue missing source artifacts now</span>
            </label>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="queue_screenshots_on_enable" value="1" />
              <span>Queue missing screenshots now</span>
            </label>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="queue_og_on_enable" value="1" />
              <span>Queue missing Open Graph now</span>
            </label>
            <label class="flex items-start gap-2">
              <input type="checkbox" name="queue_readability_on_enable" value="1" />
              <span>Queue missing readability now</span>
            </label>
          </div>

          <div>
            <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65">Save artifact settings</button>
          </div>
        </form>
      </section>

      <section class="flex flex-col gap-3 rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-3">
        <h3 class="text-lg font-semibold leading-7 tracking-tight">Process all missing artifacts</h3>
        <div class="flex flex-col gap-3">
          <div class="overflow-x-auto" aria-label="Missing artifacts summary">
            <table class="min-w-max border-collapse bg-form-control text-sm [&_th]:border [&_th]:border-form-control-border [&_th]:px-2 [&_th]:py-2 [&_th]:text-left [&_th]:font-normal [&_td]:border [&_td]:border-form-control-border [&_td]:px-2 [&_td]:py-2 [&_td]:align-top">
              <thead>
                <tr>
                  <th>Total links</th>
                  <th>Missing source</th>
                  <th>Missing Open Graph</th>
                  <th>Missing readability</th>
                  <th>Snapshot active</th>
                  <th>Open Graph active</th>
                  <th>Readability active</th>
                  <th>Snapshot to queue</th>
                  <th>Open Graph to queue</th>
                  <th>Readability to queue</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><%= self.summary.total_hyperlinks %></td>
                  <td><%= self.summary.missing_source %></td>
                  <td><%= self.summary.missing_og %></td>
                  <td><%= self.summary.missing_readability %></td>
                  <td><%= self.summary.snapshot_already_processing %></td>
                  <td><%= self.summary.og_already_processing %></td>
                  <td><%= self.summary.readability_already_processing %></td>
                  <td><%= self.summary.snapshot_will_queue %></td>
                  <td><%= self.summary.og_will_queue %></td>
                  <td><%= self.summary.readability_will_queue %></td>
                </tr>
              </tbody>
            </table>
          </div>

          <form
            action="/admin/process-missing-artifacts"
            method="post"
            class="flex flex-row flex-wrap items-center gap-[0.4rem]"
            data-confirm="Process all artifacts? This will queue snapshot, Open Graph, and readability jobs for every link missing required artifacts."
          >
            <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65"<% if !self.has_missing_artifacts_to_process { %> disabled<% } %>>Process all artifacts</button>
          </form>
        </div>
      </section>
    <% } %>

    <% if self.is_tags_tab() { %>
      <section class="flex flex-col gap-3 rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-3">
        <h3 class="text-lg font-semibold leading-7 tracking-tight">Tag classification settings</h3>
        <p class="text-sm text-tertiary">
          Configure OpenAI-compatible tag classification. API key is optional for local/custom endpoints.
        </p>
        <form action="/admin/tagging-settings" method="post" class="flex flex-col gap-3 text-sm" data-tagging-settings-form>
          <label class="flex items-start gap-2">
            <input type="checkbox" name="tagging_enabled" value="1"<% if self.tagging_settings.enabled { %> checked<% } %> class="mt-0.5 h-4 w-4 shrink-0 rounded border border-form-control-border bg-form-control accent-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
            <span>Enable automatic tag classification jobs</span>
          </label>
          <input type="hidden" name="backend_kind" value="<%= self.tagging_settings.backend_kind.as_storage() %>" data-tagging-backend-kind />

          <label class="flex flex-col gap-1">
            <span>Base URL</span>
            <input type="text" name="base_url" value="<%= self.tagging_settings.base_url %>" data-tagging-base-url class="min-h-10 w-full rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
          </label>

          <label class="flex flex-col gap-1">
            <span>Model</span>
            <select name="model" data-tagging-model-select class="min-h-10 w-full rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30">
              <option value="<%= self.tagging_settings.model %>"><%= self.tagging_settings.model %></option>
            </select>
            <div class="flex flex-row items-center gap-2">
              <button type="button" data-tagging-check-button class="inline-flex min-h-9 items-center justify-center rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-1.5 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65">Check</button>
              <span class="text-sm text-tertiary" data-tagging-model-status>Model options load from the configured endpoint.</span>
            </div>
          </label>

          <label class="flex flex-col gap-1">
            <span>API key (optional)</span>
            <input type="password" name="api_key" value="" autocomplete="off" data-tagging-api-key class="min-h-10 w-full rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
            <span class="text-sm text-tertiary">Leave blank to keep existing key.</span>
          </label>

          <label class="flex flex-col gap-1">
            <span>Auth header name (optional)</span>
            <input type="text" name="auth_header_name" value="<%= self.tagging_settings.auth_header_name.as_deref().unwrap_or("") %>" data-tagging-auth-header-name class="min-h-10 w-full rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
          </label>

          <label class="flex flex-col gap-1">
            <span>Auth header prefix (optional)</span>
            <input type="text" name="auth_header_prefix" value="<%= self.tagging_settings.auth_header_prefix.as_deref().unwrap_or("") %>" data-tagging-auth-header-prefix class="min-h-10 w-full rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
          </label>

          <label class="flex flex-col gap-1">
            <span>Topic vocabulary (comma or newline separated)</span>
            <textarea name="topic_vocabulary" rows="6" class="w-full rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"><%= self.tagging_vocabulary_lines() %></textarea>
          </label>

          <label class="flex flex-col gap-1">
            <span>Action vocabulary (comma or newline separated)</span>
            <textarea name="action_vocabulary" rows="4" class="w-full rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"><%= self.tagging_action_vocabulary_lines() %></textarea>
          </label>

          <label class="inline-flex items-start gap-2 text-sm">
            <input type="checkbox" name="auto_approve_ai" value="1"<% if self.tagging_settings.auto_approve_ai { %> checked<% } %> class="mt-0.5 h-4 w-4 shrink-0 rounded border border-form-control-border bg-form-control accent-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
            <span>Auto-approve AI tags (off = pending review)</span>
          </label>

          <div>
            <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65">Save tag settings</button>
          </div>
        </form>
      </section>

      <section class="flex flex-col gap-3 rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-3" data-admin-tag-reclassify>
        <h3 class="text-lg font-semibold leading-7 tracking-tight">Reclassify tags</h3>
        <p class="text-sm text-tertiary">Run an AI pass across every link and collect pending tag suggestions.</p>
        <div class="flex flex-row flex-wrap items-center gap-[0.4rem]">
          <button type="button" data-admin-tag-reclassify-start class="inline-flex min-h-10 items-center justify-center rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65">Reclassify all links</button>
          <button type="button" data-admin-tag-reclassify-cancel class="hidden min-h-10 rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65" disabled>Cancel reclassify</button>
        </div>
        <p class="text-sm text-tertiary" data-admin-tag-reclassify-status aria-live="polite">Reclassify is idle.</p>
        <p class="text-sm text-tertiary hidden" data-admin-tag-reclassify-progress aria-live="polite"></p>
      </section>

      <section class="flex flex-col gap-3 rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-3" data-admin-pending-tags>
        <h3 class="text-lg font-semibold leading-7 tracking-tight">Pending discovered tags</h3>
        <p class="text-sm text-tertiary">Select tags to approve. Approved topic/action tags are added to their vocabulary list.</p>
        <% if self.pending_tags.is_empty() { %>
          <p class="text-sm text-tertiary">No pending tags.</p>
        <% } else { %>
          <form action="/admin/tags/approve" method="post" class="flex flex-col gap-2">
            <div class="flex flex-col gap-1">
              <% for pending in self.pending_tags { %>
                <label class="flex items-start gap-2 text-sm">
                  <input type="checkbox" name="tag_ids" value="<%= pending.encoded_id %>" class="mt-0.5 h-4 w-4 shrink-0 rounded border border-form-control-border bg-form-control accent-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
                  <span><%= pending.kind.as_str() %>: <%= pending.name %> (<%= pending.hyperlink_count %> links)</span>
                </label>
              <% } %>
            </div>
            <div>
              <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65">Approve selected tags</button>
            </div>
          </form>
        <% } %>
      </section>
    <% } %>

    <% if self.is_queue_tab() { %>
      <section class="flex flex-col gap-3 rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-3">
        <h3 class="text-lg font-semibold leading-7 tracking-tight">Pending queue rows</h3>
        <p class="text-sm text-tertiary">
          These counts match the Queue tab badge and include only ProcessingTask rows in queued or processing states.
        </p>
        <div class="flex flex-row flex-wrap gap-[0.4rem] text-sm">
          <div class="rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-1">
            <span class="text-tertiary">Pending:</span>
            <span data-admin-queue-pending><%= self.queue_pending.pending %></span>
          </div>
          <div class="rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-1">
            <span class="text-tertiary">Queued:</span>
            <span data-admin-queue-queued><%= self.queue_pending.queued %></span>
          </div>
          <div class="rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-1">
            <span class="text-tertiary">Processing:</span>
            <span data-admin-queue-processing><%= self.queue_pending.processing %></span>
          </div>
        </div>
        <div class="flex flex-row flex-wrap items-center gap-[0.4rem] text-sm">
          <a class="text-accent no-underline hover:text-accent/80" href="/admin/jobs?status=queued">View queued rows</a>
          <a class="text-accent no-underline hover:text-accent/80" href="/admin/jobs?status=processing">View processing rows</a>
          <a class="text-accent no-underline hover:text-accent/80" href="/admin/jobs">View all queue rows</a>
        </div>
      </section>

      <section class="flex flex-col gap-3 rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-3">
        <h3 class="text-lg font-semibold leading-7 tracking-tight">Queue controls</h3>
        <p class="text-sm text-tertiary">
          Clear queued processing rows. Running, completed, and failed rows are not changed.
        </p>
        <div class="flex flex-row flex-wrap items-center gap-[0.4rem]">
          <form
            action="/admin/clear-queue"
            method="post"
            data-confirm="Clear all queued queue rows? Running jobs are not affected."
          >
            <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65">Clear queue</button>
          </form>
          <form
            action="/admin/pause-queue"
            method="post"
            data-confirm="Pause queue workers? Running tasks will finish, and new queued tasks will wait."
          >
            <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65">Pause queue</button>
          </form>
          <form action="/admin/resume-queue" method="post">
            <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65">Resume queue</button>
          </form>
          <a class="text-accent no-underline hover:text-accent/80" href="/jobs">Open raw lilqueue dashboard</a>
        </div>
      </section>
    <% } %>

    <% if self.is_import_export_tab() { %>
      <section class="flex flex-col gap-3 rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-3">
        <h3 class="text-lg font-semibold leading-7 tracking-tight">Import / Export</h3>
        <p class="text-sm text-tertiary">
          Download a full ZIP backup (including artifacts) or restore from a previously exported ZIP.
        </p>
        <div class="flex flex-col gap-[0.4rem]" data-admin-backup>
          <div class="flex flex-row flex-wrap items-center gap-[0.4rem]">
            <button type="button" data-admin-backup-create class="inline-flex min-h-10 items-center justify-center rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65">Create backup ZIP</button>
            <form action="/admin/export/cancel" method="post">
              <button type="submit" data-admin-backup-cancel class="hidden min-h-10 rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65" disabled>Cancel backup</button>
            </form>
            <a href="/admin/export/download" data-admin-backup-download class="hidden text-accent no-underline hover:text-accent/80">Download backup ZIP</a>
          </div>
          <p class="text-sm text-tertiary" data-admin-backup-status aria-live="polite">Backup is idle.</p>
          <p class="text-sm text-tertiary hidden" data-admin-backup-progress aria-live="polite"></p>
        </div>
        <div class="flex flex-col gap-[0.4rem]" data-admin-import>
          <form action="/admin/import" method="post" enctype="multipart/form-data" class="flex flex-col gap-[0.4rem]" data-admin-import-form>
            <label for="admin-import-archive" class="text-sm font-normal">Import backup ZIP</label>
            <input id="admin-import-archive" name="archive" type="file" accept=".zip,application/zip" required class="min-h-10 w-full min-w-0 rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-primary file:mr-3 file:rounded-[0.3rem] file:border-0 file:bg-tertiary/40 file:px-3 file:py-1.5 file:text-accent/90 hover:file:bg-tertiary/60 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
            <div class="flex flex-row flex-wrap items-center gap-[0.4rem]">
              <button type="submit" data-admin-import-submit class="inline-flex min-h-10 items-center justify-center rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65">Import backup ZIP</button>
            </div>
          </form>
          <form action="/admin/import/cancel" method="post">
            <button type="submit" data-admin-import-cancel class="hidden min-h-10 rounded-[0.4rem] border border-form-control-border bg-form-control px-[0.65rem] py-2 text-accent transition-colors hover:border-accent/60 hover:bg-tertiary/30 active:bg-tertiary/50 disabled:cursor-not-allowed disabled:opacity-65" disabled>Cancel import</button>
          </form>
          <p class="text-sm text-tertiary" data-admin-import-status aria-live="polite">Import is idle.</p>
          <p class="text-sm text-tertiary hidden" data-admin-import-progress aria-live="polite"></p>
        </div>
      </section>
    <% } %>

    <% if self.is_storage_tab() { %>
      <section class="flex flex-col gap-3 rounded-[0.4rem] border border-form-control-border bg-form-control px-3 py-3">
        <h3 class="text-lg font-semibold leading-7 tracking-tight">Storage utilization</h3>
        <div class="overflow-x-auto">
          <table class="min-w-max border-collapse bg-form-control text-sm [&_th]:border [&_th]:border-form-control-border [&_th]:px-2 [&_th]:py-2 [&_th]:text-left [&_th]:font-normal [&_td]:border [&_td]:border-form-control-border [&_td]:px-2 [&_td]:py-2 [&_td]:align-top" aria-label="Storage utilization summary">
            <thead>
              <tr>
                <th>Metric</th>
                <th>Size</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>DB size (SQLite main + wal + shm)</td>
                <td>
                  <%= self.format_u64_bytes(self.stats.db_size_total_bytes) %>
                  <div class="text-sm text-tertiary">main <%= self.format_u64_bytes(self.stats.db_size_main_bytes) %>, wal <%= self.format_u64_bytes(self.stats.db_size_wal_bytes) %>, shm <%= self.format_u64_bytes(self.stats.db_size_shm_bytes) %></div>
                </td>
              </tr>
              <tr>
                <td>Saved artifacts size (saved links, all types)</td>
                <td>
                  <%= self.format_i64_bytes(self.stats.saved_artifacts_size_bytes) %>
                  <div class="text-sm text-tertiary">avg <%= self.format_average_i64_bytes(self.stats.saved_artifacts_size_bytes, self.stats.saved_artifacts_count) %></div>
                </td>
              </tr>
              <tr>
                <td>Discovered artifacts size (discovered links, all types)</td>
                <td>
                  <%= self.format_i64_bytes(self.stats.discovered_artifacts_size_bytes) %>
                  <div class="text-sm text-tertiary">avg <%= self.format_average_i64_bytes(self.stats.discovered_artifacts_size_bytes, self.stats.discovered_artifacts_count) %></div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-max border-collapse bg-form-control text-sm [&_th]:border [&_th]:border-form-control-border [&_th]:px-2 [&_th]:py-2 [&_th]:text-left [&_th]:font-normal [&_td]:border [&_td]:border-form-control-border [&_td]:px-2 [&_td]:py-2 [&_td]:align-top" aria-label="Artifact storage by type">
            <thead>
              <tr>
                <th>Artifact type</th>
                <th>Saved links</th>
                <th>Discovered links</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              <% if self.stats.artifact_storage_by_kind.is_empty() { %>
                <tr>
                  <td colspan="4">No artifact storage yet.</td>
                </tr>
              <% } else { %>
                <% for entry in self.stats.artifact_storage_by_kind.iter() { %>
                  <tr>
                    <td><code><%= entry.kind %></code></td>
                    <td>
                      <%= self.format_i64_bytes(entry.saved_size_bytes) %>
                      <div class="text-sm text-tertiary">avg <%= self.format_average_i64_bytes(entry.saved_size_bytes, entry.saved_artifact_count) %></div>
                    </td>
                    <td>
                      <%= self.format_i64_bytes(entry.discovered_size_bytes) %>
                      <div class="text-sm text-tertiary">avg <%= self.format_average_i64_bytes(entry.discovered_size_bytes, entry.discovered_artifact_count) %></div>
                    </td>
                    <td>
                      <%= self.format_i64_bytes(entry.saved_size_bytes + entry.discovered_size_bytes) %>
                      <div class="text-sm text-tertiary">avg <%= self.format_average_i64_bytes(entry.saved_size_bytes + entry.discovered_size_bytes, entry.saved_artifact_count + entry.discovered_artifact_count) %></div>
                    </td>
                  </tr>
                <% } %>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>
    <% } %>
</section>
