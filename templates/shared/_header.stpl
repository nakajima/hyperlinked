<header class="mx-auto mb-4 flex w-full max-w-[75rem] flex-wrap items-center gap-4 bg-surface px-3 pt-4 sm:px-6 <% if self.has_admin_tabs() { %>pb-0<% } else { %>pb-4<% } %>">
  <h1 class="flex flex-row items-center gap-[0.4rem] font-brand text-5xl leading-none font-bold italic">
    <a href="/hyperlinks" class="text-accent no-underline hover:text-accent/80">
      <span>Hyperlinked</span>
    </a>
  </h1>

  <span class="inline-block h-12 w-12 shrink-0 text-white" aria-hidden="true"><%- self.pointer_logo_svg %></span>
  <span class="hidden flex-1 sm:block" aria-hidden="true"></span>

  <nav class="header-nav-links basis-full flex flex-col gap-1 text-sm sm:basis-auto sm:flex-row sm:flex-wrap sm:justify-end sm:gap-4">
    <a href="/hyperlinks/new" class="inline-flex min-h-11 items-center text-accent no-underline hover:text-accent/80">Add</a>
    <a href="/admin" class="inline-flex min-h-11 flex-row items-center gap-1 text-accent no-underline hover:text-accent/80">
      <span>Admin</span>
      <% if self.show_admin_warning_badge { %>
        <span
          data-admin-warning-badge
          class="rounded-[0.25rem] border border-invalid px-[0.2rem] py-1 text-[0.5rem] leading-[0.5rem] text-alert"
          title="Chromium/Chrome is not configured"
          aria-label="Chromium/Chrome setup required"
        >!</span>
      <% } %>
    </a>
  </nav>

  <% if self.has_admin_tabs() { %>
    <nav class="basis-full flex flex-row flex-wrap items-end gap-2 pt-1 text-sm" aria-label="Admin sections">
      <a href="/admin/overview" class="<%= self.admin_tab_link_class("/admin/overview") %>"<% if self.admin_tab_is_active("/admin/overview") { %> aria-current="page"<% } %>>Overview</a>
      <a href="/admin/artifacts" class="<%= self.admin_tab_link_class("/admin/artifacts") %>"<% if self.admin_tab_is_active("/admin/artifacts") { %> aria-current="page"<% } %>>Artifacts</a>
      <a href="/admin/llm-interactions" class="<%= self.admin_tab_link_class("/admin/llm-interactions") %>"<% if self.admin_tab_is_active("/admin/llm-interactions") { %> aria-current="page"<% } %>>LLM</a>
      <a href="/admin/queue" class="<%= self.admin_tab_link_class("/admin/queue") %>"<% if self.admin_tab_is_active("/admin/queue") { %> aria-current="page"<% } %>>
        <span>Queue</span>
        <span
          data-queue-pending-badge
          class="hidden rounded-[0.25rem] bg-badge px-[0.2rem] py-1 text-[0.5rem] leading-[0.5rem] text-black"
        >0</span>
      </a>
      <a href="/admin/feeds" class="<%= self.admin_tab_link_class("/admin/feeds") %>"<% if self.admin_tab_is_active("/admin/feeds") { %> aria-current="page"<% } %>>Feeds</a>
      <a href="/admin/import-export" class="<%= self.admin_tab_link_class("/admin/import-export") %>"<% if self.admin_tab_is_active("/admin/import-export") { %> aria-current="page"<% } %>>Import / Export</a>
      <a href="/admin/storage" class="<%= self.admin_tab_link_class("/admin/storage") %>"<% if self.admin_tab_is_active("/admin/storage") { %> aria-current="page"<% } %>>Storage</a>
    </nav>
  <% } %>
</header>
