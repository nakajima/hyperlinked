<section aria-labelledby="edit-link-heading">
  <h2 id="edit-link-heading">Edit Link</h2>
  <% let action = format!("/hyperlinks/{}/update", self.link.id); %>
  <% let submit_label = "Update"; %>
  <% let title = self.link.title.as_str(); %>
  <% let url = self.link.raw_url.as_str(); %>
  <% let is_new_record = false; %>
  <% include!("_form.stpl"); %>
  <p><a href="/hyperlinks/<%= self.link.id %>">Back to link</a></p>
</section>
